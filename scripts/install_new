# Write Info
############################################
create_menu_bin(){
    cat >"/usr/bin/mcnvps"<<END
#!/bin/bash

######################################################################
#           Auto Install & Optimize LEMP Stack on Ubuntu             #
#                                                                    #
#                Author: Sanvv - MCN Technical                    #
#                  Website: https://mcnvps.net                        #
#                                                                    #
#              Please do not remove copyright. Thank!                #
#  Please do not copy under any circumstance for commercial reason!  #
######################################################################

_download_mcn_menu() {
    if [[ ! -d "${BASH_DIR}" ]]; then
        mkdir -p "${BASH_DIR}"
    fi

    cd "${BASH_DIR}"
    rm -rf ./server-manager

    if [[ -f "server-manager.zip" ]]; then
        rm -f ./server-manager.zip
    fi

    wget 'https://github.com/phongnhadn1991/McnVPS/raw/master/scripts/server-manager.zip'

    if [[ -f "server-manager.zip" ]]; then
        unzip server-manager.zip
        rm -f ./server-manager.zip
        chmod +x server-manager/* server-manager/*/* server-manager/*/*/*
        dos2unix server-manager/* server-manager/*/* server-manager/*/*/*

        source "${BASH_DIR}/server-manager/routes/main_menu.sh" && main_menu || {
            clear
            echo "Da xay ra loi. Khong the download McnVPS Menu"
        }
    else
        clear
        echo "Da xay ra loi. Khong the download McnVPS Menu"
    fi
}

source "${BASH_DIR}/server-manager/routes/main_menu.sh" && main_menu || {
    _download_mcn_menu
}
END
    chmod +x /usr/bin/mcnvps
}

write_info() {


    touch "${FILE_INFO}"
    {
        echo "script_version=${SCRIPTS_VERSION}"
        echo "admin_port=${RANDOM_ADMIN_PORT}"
        echo "mysql_user=sqladmin"
        echo "mysql_admin_pwd=${SQL_ADMIN_PASS}"
        echo "mysql_root_pwd=${SQL_ROOT_PASS}"
        echo "admin_email=${ADMIN_EMAIL}"
        echo "webserver=nginx"
        echo "lang=vi"
    } >>"${FILE_INFO}"

    touch /etc/mcnvps.lock
    chmod 600 "${FILE_INFO}" /etc/mcnvps.lock

    cat >"/root/.my.cnf"<<END
[client]
user='root'
password='${SQL_ROOT_PASS}'
END
    chmod 600 /root/.my.cnf
}

_add_cronjob() {
    local pattern="$1"
    local line="$2"

    crontab -l 2>/dev/null | grep -v "$pattern" > /tmp/mycron.$$ || true

    echo "$line" >> /tmp/mycron.$$

    crontab /tmp/mycron.$$
    rm -f /tmp/mycron.$$
}

create_cronjob() {
    if [ -e '/var/mcnvps/server-manager/cronjob/mcnvps_backup' ]; then
        chmod +x /var/mcnvps/server-manager/cronjob/mcnvps_backup
        _add_cronjob "/mcnvps_backup" \
            '0 3 * * * /var/mcnvps/server-manager/cronjob/mcnvps_backup >/dev/null 2>&1'
    fi

    if [ -e '/root/.acme.sh/acme.sh' ]; then
        _add_cronjob "/acme\.sh" \
            '0 0 * * * "/root/.acme.sh"/acme.sh --cron --home "/root/.acme.sh" >/dev/null 2>&1'
    fi

    _add_cronjob "sign_new_ssl\.bash" \
        '* * * * * /usr/bin/bash /var/mcnvps/server-manager/cronjob/sign_new_ssl.bash >/dev/null 2>&1'

    _add_cronjob "update_cf_ip\.bash" \
            '30 0 * * * /usr/bin/bash /var/mcnvps/server-manager/cronjob/update_cf_ip.bash >/dev/null 2>&1'

    _add_cronjob "wp_cron\.bash" \
        '15 0 * * * /usr/bin/bash /var/mcnvps/server-manager/cronjob/wp_cron.bash >/dev/null 2>&1'

    _add_cronjob "service_notify\.bash" \
            '* * * * * /usr/bin/bash /var/mcnvps/server-manager/cronjob/service_notify.bash >/dev/null 2>&1'
}

############################################
# Check Condition
############################################

if [[ "$(id -u)" != "0" ]]; then
    printf "${RED}%s${NC}\n" "${ROOT_ERR}"
    printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
    exit
fi

if [[ "${CPU_ARCHITECTURE}" != 'x86_64' && "${CPU_ARCHITECTURE}" != 'amd64' ]]; then
    printf "${RED}%s${NC}\n" "${CPU_NOT_SUPPORT}"
    printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
    exit
fi

if [[ ${RAM_TOTAL} -lt ${LOW_RAM} ]]; then
    printf "${RED}%s${NC}\n" "${RAM_NOT_ENOUGH}"
    printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
    exit
fi

if [[ "$ID" == "ubuntu" ]]; then
    if [[ ! " ${UBUNTU_OS_VERSION_LIST[*]} " =~ (^|[[:space:]])${VERSION_ID}([[:space:]]|$) ]]; then
        printf "${RED}%s${NC}\n" "${WRONG_VERSION}"
        printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
        exit
    fi
elif [[ "$ID" == "debian" ]]; then
    if [[ ! " ${DEBIAN_OS_VERSION_LIST[*]} " =~ (^|[[:space:]])${VERSION_ID}([[:space:]]|$) ]]; then
        printf "${RED}%s${NC}\n" "${WRONG_VERSION}"
        printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
        exit 1
    fi
else
    printf "${RED}%s${NC}\n" "${WRONG_OS}"
    printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
    exit
fi

if [[ -n "$(which nginx)" || -n "$(which mysql)" || -n "$(which mysqld)" || -n "$(which mariadb)" || -n "$(which docker)" ]]; then
    printf "${RED}%s${NC}\n" "${SERVICE_EXISTS}"
    printf "${RED}%s${NC}\n" "${CANCEL_INSTALL}"
    exit
fi

_write_log

if [[ -z "$(which wget)" || -z "$(which curl)" || -z "$(which perl)" ]]; then
    # shellcheck disable=SC2059
    printf "${RED}Missing Wget or Curl or Perl${NC}\n"
    exit 1
fi

