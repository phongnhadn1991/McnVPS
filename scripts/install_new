        PHP_REDIS_VERSION="5.3.7"
    elif [[ $PHP_MINOR_VERSION -lt 4 ]]; then
        PHP_REDIS_VERSION="6.0.2"
    fi
fi

case "$PHP_MAJOR_VERSION" in
    8)
        if (( PHP_MINOR_VERSION >= 1 )); then
            CACHE_TOOL_VER=$(extract_key_value "$VERSION_RESPONSE" "cache_tool_ver")
        else
            CACHE_TOOL_VER="8.6.1"
        fi
        ;;
    7)
        if (( PHP_MINOR_VERSION >= 3 )); then
            CACHE_TOOL_VER="7.1.0"
        elif (( PHP_MINOR_VERSION == 2 )); then
            CACHE_TOOL_VER="5.1.3"
        else
            CACHE_TOOL_VER=''
        fi
        ;;
    *)
        CACHE_TOOL_VER=''
        ;;
esac

set_lib_link() {

    #NGX_ACME_LINK="${MODULE_LINK}/ngx-acme/${NGINX_VERSION}/${ID}-${VERSION_ID}/ngx_http_acme_module.so"
    if [ -n "$CACHE_TOOL_VER" ]; then
        CACHE_TOOL_LINK="${MODULE_LINK}/cache-tool/${CACHE_TOOL_VER}/cachetool.phar"
    fi

    if [[ "$VPS_COUNTRY" == "VN" ]]; then
        NGINX_LINK="${MODULE_LINK}/nginx-${NGINX_VERSION}.tar.gz"
        HMNM_LINK="${MODULE_LINK}/headers-more-nginx-module-${more_clear_headers_v}.tar.gz"
        GEOIP2_LINK="${MODULE_LINK}/ngx_http_geoip2_module-${ngx_http_geoip2_module_v}.tar.gz"
        NGX_TLS_DYN_SIZE_LINK="${MODULE_LINK}/nginx__dynamic_tls_records_${NGX_TLS_DYN_SIZE_VER}%2B.patch"
        ROCKET_NGINX_LINK="${MODULE_LINK}/rocket-nginx-v${ROCKET_NGINX_VER}.tar.gz"

        IG_BINARY_LINK="${MODULE_LINK}/igbinary-${IG_BINARY_VERSION}.tgz"
        PHP_MEMCACHED_LINK="${MODULE_LINK}/memcached-${PHP_MEMCACHED_VERSION}.tgz"
        PHP_REDIS_LINK="${MODULE_LINK}/redis-${PHP_REDIS_VERSION}.tgz"
        IONCUBE_LINK="${MODULE_LINK}/ioncube_loaders_lin_x86-64.tar.gz"

        PHP_MYADMIN_LINK="${MODULE_LINK}/phpMyAdmin-${PHPMYADMIN_VERSION}-english.tar.gz"

        MARIADB_REPO_LINK="${MODULE_LINK}/mariadb_repo_setup"

        WP_CLI_LINK="${MODULE_LINK}/wp-cli-${WP_CLI_VERSION}.phar"
        COMPOSER_LINK="${MODULE_LINK}/composer/${COMPOSER_VERSION}/composer.phar"

        COUNTRY_ASN_LINK="${MODULE_LINK}/country_asn.mmdb"
        FAIL2BAN_LINK="${MODULE_LINK}/fail2ban_${FAIL2BAN_VER}_all.deb"
        RCLONE_LINK="${MODULE_LINK}/rclone/rclone-current-linux-amd64.zip"
    else
        NGINX_LINK="https://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz"
        HMNM_LINK="https://github.com/openresty/headers-more-nginx-module/archive/refs/tags/v${more_clear_headers_v}.tar.gz"
        GEOIP2_LINK="https://github.com/leev/ngx_http_geoip2_module/archive/refs/tags/${ngx_http_geoip2_module_v}.tar.gz"
        NGX_TLS_DYN_SIZE_LINK="https://raw.githubusercontent.com/nginx-modules/ngx_http_tls_dyn_size/refs/heads/master/nginx__dynamic_tls_records_${NGX_TLS_DYN_SIZE_VER}%2B.patch"
        ROCKET_NGINX_LINK="https://github.com/SatelliteWP/rocket-nginx/archive/refs/tags/v${ROCKET_NGINX_VER}.tar.gz"

        IG_BINARY_LINK="https://pecl.php.net/get/igbinary-${IG_BINARY_VERSION}.tgz"
        PHP_MEMCACHED_LINK="https://pecl.php.net/get/memcached-${PHP_MEMCACHED_VERSION}.tgz"
        PHP_REDIS_LINK="https://pecl.php.net/get/redis-${PHP_REDIS_VERSION}.tgz"
        IONCUBE_LINK='https://downloads.ioncube.com/loader_downloads/ioncube_loaders_lin_x86-64.tar.gz'

        PHP_MYADMIN_LINK="https://files.phpmyadmin.net/phpMyAdmin/${PHPMYADMIN_VERSION}/phpMyAdmin-${PHPMYADMIN_VERSION}-english.tar.gz"

        MARIADB_REPO_LINK='https://r.mariadb.com/downloads/mariadb_repo_setup'

        WP_CLI_LINK="https://github.com/wp-cli/wp-cli/releases/download/v${WP_CLI_VERSION}/wp-cli-${WP_CLI_VERSION}.phar"
        COMPOSER_LINK="https://getcomposer.org/download/${COMPOSER_VERSION}/composer.phar"

        COUNTRY_ASN_LINK="${MODULE_LINK}/country_asn.mmdb"
        FAIL2BAN_LINK="https://launchpad.net/ubuntu/+archive/primary/+files/fail2ban_${FAIL2BAN_VER}_all.deb"
        RCLONE_LINK="https://downloads.rclone.org/rclone-current-linux-amd64.zip"
    fi
}

