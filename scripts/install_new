        build-essential gcc g++ make cmake diffutils perl tar zip unzip curl \
        openssl quota logrotate rsyslog zstd git procps file e2fsprogs xfsprogs hostname libgeoip-dev \
        iproute2 cron ca-certificates net-tools gettext media-types python3 debianutils python3-apt python3-systemd \
        bc libmaxminddb-dev curl wget nano htop dos2unix ipcalc patch dnsutils libwww-perl bzip2 \
        apache2-dev libjpeg-dev libpng-dev libtiff-dev libgif-dev libwebp-dev webp libbrotli-dev libssl-dev \
        libmemcached-dev expect libnss3-tools libzstd-dev liblz4-dev sipcalc grepcidr rsync gnupg2 libclang-dev \
        iftop iotop vnstat sshpass p7zip-full jq mmdb-bin

    if [[ "$ID" == 'ubuntu' ]]; then
        apt-get install -y unrar
    elif [[ "$ID" == 'debian' ]]; then
        if grep -q 'non-free' /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources 2>/dev/null; then
            apt-get install -y unrar
        fi
    fi

#    safe_apt_install "rust" rustup
#    if [[ -n "$(which rustup)" ]]; then
#        rustup default stable
#    fi

#    service supervisor stop
#    systemctl disable supervisor

    # Add redis repo
#    if [[ "$ID" != 'debian' && "$VERSION_ID" != '12' ]]; then
#        apt-get install lsb-release curl gpg -y
#        curl -fsSL https://packages.redis.io/gpg | gpg --dearmor -o /usr/share/keyrings/redis-archive-keyring.gpg
#        chmod 644 /usr/share/keyrings/redis-archive-keyring.gpg
#        echo "deb [signed-by=/usr/share/keyrings/redis-archive-keyring.gpg] https://packages.redis.io/deb $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/redis.list
#        apt-get update
#    fi

    # Add PHP Repo
    if [ "${ID}" == 'ubuntu' ]; then
        add-apt-repository -y ppa:ondrej/php

    elif [ "$ID" == 'debian' ]; then
        curl https://packages.sury.org/php/apt.gpg | gpg --dearmor | sudo tee /usr/share/keyrings/php-sury-keyring.gpg >/dev/null
        echo "deb [signed-by=/usr/share/keyrings/php-sury-keyring.gpg] https://packages.sury.org/php/ $(lsb_release -cs) main" |
            tee /etc/apt/sources.list.d/php.list
    fi

    apt-get update
}

