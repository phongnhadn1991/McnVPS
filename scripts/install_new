printf "Link phpMyAdmin              : %s\n" "http://${IPADDRESS}:${RANDOM_ADMIN_PORT}/phpmyadmin"
printf "User phpMyAdmin              : sqladmin\n"
printf "Password phpMyAdmin          : %s\n" "${SQL_ADMIN_PASS}"
printf ""
printf "Go lenh ${RED}mcnvps${NC} hoac ${RED}mcn${NC} de mo menu\n"
printf ""
printf "=========================================================================\n"

echo -e "${RED}⚠️  He thong sẽ khoi dong lai sau 5 giây. Vui long đung thao tac gi trong luc nay!${NC}"
