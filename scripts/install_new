config_geoip2() {
    GEO_CONFIG_FILE='/etc/nginx/nginx-geo.conf'

    cat >"${GEO_CONFIG_FILE}" <<END
geoip2 /etc/nginx/geo/country_asn.mmdb {
    auto_reload 7d;
    \$geoip2_data_continent continent;
    \$geoip2_data_country_name country;
    \$geoip2_asn asn;
    \$geoip2_organization as_name;
}
END

    {
        while read -r ip; do
            [[ -n "$ip" ]] && echo "geoip2_proxy $ip;"
        done < "$CF_IPV4_FILE"

        while read -r ip; do
            [[ -n "$ip" ]] && echo "geoip2_proxy $ip;"
        done < "$CF_IPV6_FILE"

        echo "geoip2_proxy_recursive on;"
    } >> "$GEO_CONFIG_FILE"
}

############################################
# Some Tweak
############################################

config_sysctl() {
    cp /etc/sysctl.conf /etc/sysctl.conf.bak
    cat >"/etc/sysctl.conf" <<ENDsysctl
# Increase size of file handles and inode cache
fs.file-max = 209708

# Do less swapping
vm.swappiness = 1
vm.dirty_ratio = 10
vm.dirty_background_ratio = 5
vm.vfs_cache_pressure=50

# 50% overcommitment of available memory
vm.overcommit_ratio = 50
vm.overcommit_memory = 1

# Use BBR TCP congestion control and set tcp_notsent_lowat to 16384 to ensure HTTP/2 prioritization works optimally
# Do a 'modprobe tcp_bbr' first (kernel > 4.9)
# Fall-back to htcp if bbr is unavailable (older kernels)
# For servers with tcp-heavy workloads, enable 'fq' queue management scheduler (kernel > 3.12)
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr
net.ipv4.tcp_notsent_lowat = 16384
ENDsysctl

    sysctl -p
}

config_logrotate() {
    cat >"/etc/logrotate.d/mcnvps" <<END
${DEFAULT_DIR_TOOL}/phpmyadmin/logs/*.log /var/log/sign-ssl/errors/*.log {
    daily
    dateext
    dateformat -%Y-%m-%d
    missingok
    rotate 7
    notifempty
    create 640 root adm
    minsize 50M
    maxsize 200M
    compress
    delaycompress
    sharedscripts
}
END

    cat >"/etc/logrotate.d/nginx" <<END
/var/log/nginx/*/*.log /home/*/*/logs/access/*.log /home/*/*/logs/errors/*.log {
    daily
    dateext
    dateformat -%Y-%m-%d
    missingok
    rotate 14
    notifempty
    create 640 root adm
    minsize 50M
    maxsize 200M
    compress
    delaycompress
    sharedscripts
    postrotate
        if [ -f /var/run/nginx.pid ]; then
            kill -USR1 \`cat /var/run/nginx.pid\`
        fi
    endscript
}
END

    cat >"/etc/logrotate.d/php${PHP_VERSION}-fpm" <<END
/var/log/php-fpm/*/*.log /home/*/*/php/logs {
    rotate 14
    daily
    dateext
    dateformat -%Y-%m-%d
    missingok
    notifempty
    minsize 50M
    maxsize 500M
    compress
    delaycompress
    sharedscripts
    postrotate
        if [ -x /usr/lib/php/php${PHP_VERSION}-fpm-reopenlogs ]; then
            /usr/lib/php/php${PHP_VERSION}-fpm-reopenlogs;
        fi
    endscript
}
END

    cat >"/etc/logrotate.d/mariadb" <<END
/var/lib/mysql/mysqld.log /var/lib/mysql/mariadb.log /var/log/mysql/*.log {
    #su mysql mysql
    rotate 6
    monthly
    missingok
    notifempty
    compress
    delaycompress
    minsize 50M
    maxsize 500M
    sharedscripts
    postrotate
        if test -r /etc/mysql/debian.cnf
        then
            EXTRAPARAM='--defaults-file=/etc/mysql/debian.cnf'
        fi

        if test -x /usr/bin/mariadb-admin
        then
            /usr/bin/mariadb-admin \$EXTRAPARAM --local flush-error-log \
                flush-engine-log flush-general-log flush-slow-log
        fi
    endscript
}
END
}

increase_command_history() {
    sed -i "s/HISTSIZE=.*/HISTSIZE=20000/g" /root/.bashrc
    sed -i "s/HISTFILESIZE=.*/HISTFILESIZE=20000/g" /root/.bashrc
}

fix_hosts_file() {
    # shellcheck disable=SC2002
    # shellcheck disable=SC2143
    if [[ -z "$(cat /etc/hosts | grep '127.0.0.1.*.localhost')" ]]; then
        echo "127.0.0.1 localhost" >> /etc/hosts
    fi
}

fix_usr_sbin_sendmail() {
    if [ ! -e '/usr/sbin/sendmail' ]; then
        touch /usr/sbin/sendmail
        chmod +x /usr/sbin/sendmail
    fi
}

############################################
# Setup FW
############################################
setup_nf_tables(){
    apt purge firewalld -y
    apt purge ufw -y
    apt purge iptables -y
    apt autoremove -y

    if [ -z "$(which nft)" ]; then
        apt-get install nftables -y
        systemctl enable nftables.service
    fi

    if [ -e '/etc/nftables.conf' ]; then
        mv /etc/nftables.conf /etc/nftables.conf.bak
    fi

    local ssh_port
    ssh_port=$(detect_ssh_port)

    cat >'/etc/nftables.conf'<<END
#!/usr/sbin/nft -f

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority filter;
    }
    chain forward {
        type filter hook forward priority filter;
    }
    chain output {
        type filter hook output priority filter;
    }
}

table ip filter {
    set allowed_tcp_ports {
        type inet_service
        elements = { 80, 443, 53, 110, 143, 993, 995, 465, 587, ${RANDOM_ADMIN_PORT}, ${ssh_port} }
    }

    set allowed_udp_ports {
        type inet_service
        elements = { 80, 443 }
    }

    set blocked_ips {
        type ipv4_addr
        flags interval
    }

    chain INVDROP {
       counter drop
    }

    chain INVALID {
        ct state invalid counter jump INVDROP
        tcp flags ! fin,syn,rst,psh,ack,urg counter jump INVDROP
        tcp flags fin,syn,rst,psh,ack,urg / fin,syn,rst,psh,ack,urg counter jump INVDROP
        tcp flags fin,syn / fin,syn counter jump INVDROP
        tcp flags syn,rst / syn,rst counter jump INVDROP
        tcp flags fin,rst / fin,rst counter jump INVDROP
        tcp flags fin / fin,ack counter jump INVDROP
        tcp flags psh / psh,ack counter jump INVDROP
        tcp flags urg / ack,urg counter jump INVDROP
        tcp flags != syn / fin,syn,rst,ack ct state new counter jump INVDROP
    }

    chain block_port_by_ip {

    }

    chain allow_port_by_ip {

    }

    chain input {
        type filter hook input priority filter; policy drop;

        iifname "lo" counter accept

        ip saddr @blocked_ips counter drop
        ip saddr @blocked_ips icmp type echo-request counter drop

        # Fragments Packets
        ip frag-off & 8191 != 0 counter drop

        iifname != "lo" meta l4proto tcp counter jump INVALID

        iifname != "lo" ct state related,established counter accept

        jump block_port_by_ip
        jump allow_port_by_ip

        iifname != "lo" meta l4proto udp ct state new udp dport @allowed_udp_ports counter accept
        iifname != "lo" meta l4proto tcp ct state new tcp dport @allowed_tcp_ports counter accept
        icmp type echo-request counter accept
        counter drop
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
    }
}

table ip6 filter {
    set allowed_tcp_ports {
        type inet_service
        elements = { 80, 443, 53, 110, 143, 993, 995, 465, 587, ${RANDOM_ADMIN_PORT}, ${ssh_port} }
    }

    set allowed_udp_ports {
        type inet_service
        elements = { 80, 443 }
    }

    set blocked_ips {
        type ipv6_addr
        flags interval
    }

    chain INVDROP {
       counter drop
    }

    chain INVALID {
        ct state invalid counter jump INVDROP
        tcp flags ! fin,syn,rst,psh,ack,urg counter jump INVDROP
        tcp flags fin,syn,rst,psh,ack,urg / fin,syn,rst,psh,ack,urg counter jump INVDROP
        tcp flags fin,syn / fin,syn counter jump INVDROP
        tcp flags syn,rst / syn,rst counter jump INVDROP
        tcp flags fin,rst / fin,rst counter jump INVDROP
        tcp flags fin / fin,ack counter jump INVDROP
        tcp flags psh / psh,ack counter jump INVDROP
        tcp flags urg / ack,urg counter jump INVDROP
        tcp flags != syn / fin,syn,rst,ack ct state new counter jump INVDROP
    }

    chain block_port_by_ip6 {

    }

    chain allow_port_by_ip6 {

    }

    chain input {
        type filter hook input priority filter; policy drop;

        iifname "lo" counter accept

        ip6 saddr @blocked_ips counter drop
        ip6 saddr @blocked_ips icmpv6 type echo-request counter drop

        iifname != "lo" meta l4proto tcp counter jump INVALID

        iifname != "lo" ct state related,established counter accept

        jump block_port_by_ip6
        jump allow_port_by_ip6

        iifname != "lo" meta l4proto udp ct state new udp dport @allowed_udp_ports counter accept
        iifname != "lo" meta l4proto tcp ct state new tcp dport @allowed_tcp_ports counter accept
        icmpv6 type echo-request counter accept
        counter drop
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
    }
}
END

    run_or_exit '' systemctl restart nftables
}

install_fail2ban() {
    cd_dir "$BUILD_DIR"

    dpkg -i "fail2ban_${FAIL2BAN_VER}_all.deb"
    delete_file "fail2ban_${FAIL2BAN_VER}_all.deb"

    if [ -z "$(which fail2ban-client)" ]; then
        clear
        echo "${RED}❌ Khong the cai dat fail2ban${NC}"
        sleep 5
    fi

    #safe_apt_install "cac goi thu vien can thiet cho he thong va build toolchain" fail2ban

    cp /etc/fail2ban/jail.{conf,local}

    cat >"/etc/fail2ban/filter.d/phpmyadmin-authlog.conf" <<END
[INCLUDES]

before = common.conf

[Definition]

failregex = ^%(__prefix_line)suser denied: \S+ \(mysql-denied\) from <HOST>\s*$

ignoreregex =
END

    cat >"/etc/fail2ban/jail.d/00-defaults-debian.local" <<END
[DEFAULT]
ignoreip   = 127.0.0.1
destemail  = ${ADMIN_EMAIL}
sender     = ${ADMIN_EMAIL}
bantime    = 4h
findtime   = 15m
banaction  = nftables-multiport
banaction_allports = nftables-allports
END

    cat >"/etc/fail2ban/jail.d/phpmyadmin-authlog.local" <<END
[phpmyadmin-authlog]
enabled  = true
filter   = phpmyadmin-authlog
port     = ${RANDOM_ADMIN_PORT}
logpath  = ${DEFAULT_DIR_TOOL}/phpmyadmin/logs/auth_fail.log
maxretry = 5
END

    local ssh_port
    ssh_port=$(detect_ssh_port)

    cat >"/etc/fail2ban/jail.d/sshd.local" <<END
[sshd]
enabled  = true
filter   = sshd
port     = ${ssh_port}
bantime  = 24h
logpath  = %(sshd_log)s
maxretry = 5
END

    #sed -i "s|^#allowipv6 =.*|allowipv6 = auto|g" /etc/fail2ban/fail2ban.conf

    systemctl restart fail2ban
    systemctl enable fail2ban
}

############################################
# Restrict apt install, apt upgrade
############################################
apt_mark_hold() {
    if [[ ! -d '/etc/apt/preferences.d' ]]; then
        apt-mark hold nginx nginx-core nginx-common nginx-full fail2ban mariadb-server mariadb-backup
    else
        cat <<EOF >/etc/apt/preferences.d/mcnvps-custom-hold
Package: nginx*
Pin: release *
Pin-Priority: -1

Package: fail2ban
Pin: release *
Pin-Priority: -1

Package: mariadb-server
Pin: release *
Pin-Priority: -1

Package: mariadb-backup
Pin: release *
Pin-Priority: -1
EOF
    fi
}

