_write_log() {
    LOGFILE="/var/log/mcnvps_install.log"
    rm -f "$LOGFILE"
    mkdir -p /var/log
    touch "$LOGFILE"
    chmod 600 "$LOGFILE"
    exec > >(tee -a "$LOGFILE") 2>&1
}

_trim() {
    local value=$1
    echo "$value" | tr -d '[:space:]'
}

cd_dir() {
    cd "$1" || return
}

get_main_ip() {
    local ip_addr
    ip_addr="$(ip route get to 8.8.8.8 2> /dev/null | grep -m 1 -o 'src [0-9.]*' | cut -d ' ' -f 2)"

    if [ -z "$ip_addr" ]; then
        ip_addr=$(_trim "$(curl "https://checkip.amazonaws.com")")
    fi

    echo "$ip_addr"
}

IPADDRESS=$(get_main_ip)

detect_country() {
    local country

    apt-get install whois -y

    country=$(whois "$IPADDRESS" | grep -i "^country" | head -n1 | awk '{print $2}')
    VPS_COUNTRY="${country:-UNKNOWN}"
}

detect_ssh_port() {
    if sshd_path=$(command -v sshd 2>/dev/null); then
        if port_from_t=$($sshd_path -T 2>/dev/null | awk '/^port /{print $2; exit}'); then
            if [[ -n "$port_from_t" ]]; then
                printf '%s' "$port_from_t"
                return 0
            fi
        fi
    fi

    if [[ -r /etc/ssh/sshd_config ]]; then
        port_from_conf=$(awk '
            BEGIN{port=""}
            /^[[:space:]]*#/ { next }                 # bỏ comment
            /^[[:space:]]*Port[[:space:]]+/ {
                for(i=2;i<=NF;i++){
                    if($i ~ /^[0-9]+$/){ print $i; exit }
                }
            }
        ' /etc/ssh/sshd_config)
        if [[ -n "$port_from_conf" ]]; then
            printf '%s' "$port_from_conf"
            return 0
        fi
    fi

    if command -v ss >/dev/null 2>&1; then
        port_from_ss=$(ss -tlnp 2>/dev/null | awk '/sshd/ {
            for(i=1;i<=NF;i++){
                if($i ~ /:[0-9]+$/){
                    split($i,a,":"); print a[length(a)]; exit
                }
            }
        }')
        if [[ -n "$port_from_ss" ]]; then
            printf '%s' "$port_from_ss"
            return 0
        fi
    elif command -v netstat >/dev/null 2>&1; then
        port_from_netstat=$(netstat -tlnp 2>/dev/null | awk '/sshd/ {
            for(i=1;i<=NF;i++){
                if($i ~ /:[0-9]+$/){
                    split($i,a,":"); print a[length(a)]; exit
                }
            }
        }')
        if [[ -n "$port_from_netstat" ]]; then
            printf '%s' "$port_from_netstat"
            return 0
        fi
    fi

    printf '22'
    return 0
}

detect_country

delete_file() {
    local file=$1
    if [ -e "$file" ]; then
        rm -f "$file"
    fi
}

delete_dir() {
    local directory=$1

    if [ -d "$directory" ]; then
        rm -rf "$directory"
    fi
}

gen_pass() {
    PERL=$(which perl)
    PASS_LEN=$($PERL -le 'print int(rand(6))+12')
    START_LEN=$($PERL -le 'print int(rand(8))+1')
    END_LEN=$((PASS_LEN - START_LEN))
    NUMERIC_CHAR=$($PERL -le 'print int(rand(10))')
    PASS_START=$($PERL -le "print map+(A..Z,a..z,0..9)[rand 62],0..$START_LEN")
    PASS_END=$($PERL -le "print map+(A..Z,a..z,0..9)[rand 62],0..$END_LEN")
    PASS=${PASS_START}${NUMERIC_CHAR}${PASS_END}
    echo "$PASS"
}

random_string() {
    STRING=$($(which perl) -le "print map+(A..Z,a..z,0..9)[rand 62],0..$1")
    echo "$STRING"
}

valid_ip() {
    local ip=$1
    if [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
        IFS='.' read -r a b c d <<<"$ip"
        for octet in $a $b $c $d; do
            [[ $octet -ge 0 && $octet -le 255 ]] || return 1
        done
        return 0
    elif [[ "$ip" =~ ^([a-fA-F0-9:]+:+)+[a-fA-F0-9]+$ ]]; then
        ping6 -c 1 -w 1 "$ip" >/dev/null 2>&1 && return 0
        return 1
    else
        return 1
    fi
}

set_timezone() {
    if [[ -f "/etc/localtime" && -f "/usr/share/zoneinfo/Asia/Ho_Chi_Minh" ]]; then
        delete_file /etc/localtime
        ln -sf /usr/share/zoneinfo/Asia/Ho_Chi_Minh /etc/localtime
    else
        timedatectl set-timezone Asia/Ho_Chi_Minh
    fi
}

extract_key_value() {
    local input=$1
    local key=$2
    local strip_space=${3:-true}
    local value

    value=$(echo "$input" | grep -m1 "^${key}=" | cut -d'=' -f2-)

    if [[ "$strip_space" == "true" ]]; then
        value=$(_trim "$value")
    fi

    echo "$value"
}

run_or_exit() {
    local desc="$1"
    shift
    echo "🔧 $desc..."
    "$@"
    local status=$?

    if [[ $status -ne 0 ]]; then
        # shellcheck disable=SC2059
        printf "${RED}❌ Loi khi $desc${NC}\n"
        # shellcheck disable=SC2059
        printf "${RED}↳ Lenh loi: $*${NC}\n"
        exit $status
    fi
}

retry_run() {
    local max_retry=$1
    local delay=$2
    local description=$3
    shift 3
    local count=1

    while ((count <= max_retry)); do
        echo "🔁 Attempt $count: $description"
        if "$@"; then
            return 0
        fi
        echo "⚠️ Failed (attempt $count). Retrying in ${delay}s..."
        ((count++))
        sleep "$delay"
    done

    echo "❌ Failed after $max_retry attempts: $description"
    return 1
}

retry_with_capture() {
    local __result_var=$1
    local max_retry=$2
    local delay=$3
    local description=$4
    shift 4

    local count=1
    local output

    while ((count <= max_retry)); do
        echo "🔁 Attempt $count: $description"

        output="$("$@")" && {
            printf -v "$__result_var" "%s" "$output"
            return 0
        }

        echo "⚠️ Failed (attempt $count). Retrying in ${delay}s..."
        ((count++))
        sleep "$delay"
    done

    echo "❌ Failed after $max_retry attempts: $description"
    return 1
}

wget_with_retry() {
    local url=$1
    local output=$2
    local max_retry=${3:-5}
    local delay=3

    retry_run "$max_retry" "$delay" "Downloading $output" \
        wget --timeout=30 --tries=3 --waitretry=2 --retry-connrefused -O "$output" "$url"
}

curl_get_with_retry() {
    local url=$1
    local max_retry=${2:-5}
    local timeout=${3:-10}
    local delay=3
    local result=''

    retry_with_capture result "$max_retry" "$delay" "Fetching $url" \
        curl -fsSL --connect-timeout "$timeout" "$url" || return 1

    echo "$result"
}

git_clone_with_retry() {
    local repo_url=$1
    local repo_dir=$2
    local max_retry=${3:-5}
    local delay=3

    retry_run "$max_retry" "$delay" "Cloning $repo_url" bash -c "
        rm -rf '$repo_dir' && \
        git clone --recurse-submodules -j8 '$repo_url' '$repo_dir'
    "
}

extract_file() {
    local file=$1
    if [ ! -e "$file" ]; then
        # shellcheck disable=SC2059
        printf "${RED}%s does not exists${NC}\n" "$file"
        exit 1
    fi

    case "$file" in
        *.tar)
            tar -xvf "$file"
            ;;
        *.tar.gz|*.tgz)
            tar -xvzf "$file"
            ;;
        *.tar.bz2|*.tbz2)
            tar -xvjf "$file"
            ;;
        *.tar.xz|*.txz)
            tar -xvJf "$file"
            ;;
        *.gz)
            gunzip "$file"
            ;;
        *.bz2)
            bunzip2 "$file"
            ;;
        *.xz)
            unxz "$file"
            ;;
        *.zip)
            unzip "$file"
            ;;
        *)
            printf "${RED}❌ Khong ho tro dinh dang file: %s${NC}\n" "$file"
            exit 1
            ;;
    esac
}

safe_apt_install() {
    local description="$1"
    shift
    echo "📦 Dang cai: ${description}"
    if ! apt-get install -y "$@"; then
        printf "${RED}❌ Loi khi cai dat: %s${NC}\n" "${description}"
        exit 1
    fi
}

