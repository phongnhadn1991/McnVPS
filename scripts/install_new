download_requirement_module() {
    echo "📦 Dang tai cac thu vien can thiet"
    delete_dir "${BUILD_DIR}"
    mkdir -p "${BUILD_DIR}"

    # Download Nginx and other dependencies
    mkdir -p /etc/nginx/geo && cd_dir /etc/nginx/geo
    wget_with_retry "$COUNTRY_ASN_LINK" "country_asn.mmdb" 5 || exit 1

    cd_dir "${BUILD_DIR}"
    wget_with_retry "$NGINX_LINK" "nginx-${NGINX_VERSION}.tar.gz" 5 || exit 1
    run_or_exit "" extract_file "nginx-${NGINX_VERSION}.tar.gz" && delete_file "nginx-${NGINX_VERSION}.tar.gz"

    wget_with_retry "$HMNM_LINK" "headers-more-nginx-module-${more_clear_headers_v}.tar.gz" 5 || exit 1
    run_or_exit "" extract_file "headers-more-nginx-module-${more_clear_headers_v}.tar.gz" && delete_file "headers-more-nginx-module-${more_clear_headers_v}.tar.gz"

    wget_with_retry "$GEOIP2_LINK" "ngx_http_geoip2_module-${ngx_http_geoip2_module_v}.tar.gz" 5 || exit 1
    run_or_exit "" extract_file "ngx_http_geoip2_module-${ngx_http_geoip2_module_v}.tar.gz" && delete_file "ngx_http_geoip2_module-${ngx_http_geoip2_module_v}.tar.gz"

    #wget_with_retry "$NGX_ACME_LINK" "ngx_http_acme_module.so" 5 || exit 1

    if [ -d "${BUILD_DIR}/ngx_brotli" ]; then
        delete_dir "${BUILD_DIR}/ngx_brotli"
    fi

    cd_dir "${BUILD_DIR}"

    if [ "$VPS_COUNTRY" == 'VN' ]; then
        wget_with_retry "${MODULE_LINK}/ngx_brotli.tar.gz" "ngx_brotli.tar.gz" 5 || exit 1
        run_or_exit "" extract_file "ngx_brotli.tar.gz" && delete_file "ngx_brotli.tar.gz"
    else
        git_clone_with_retry "https://github.com/google/ngx_brotli" "ngx_brotli" 5 || exit 1
    fi

    cd_dir "${BUILD_DIR}/ngx_brotli/deps/brotli"
    mkdir -p out && cd_dir out
    cmake -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF -DCMAKE_C_FLAGS="-Ofast -m64 -march=native -mtune=native -flto -funroll-loops -ffunction-sections -fdata-sections -Wl,--gc-sections" -DCMAKE_INSTALL_PREFIX=./installed ..
    cmake --build . --config Release --target brotlienc

    cd_dir "${BUILD_DIR}"/nginx-"${NGINX_VERSION}"/
    wget_with_retry "$NGX_TLS_DYN_SIZE_LINK" "nginx__dynamic_tls_records_${NGX_TLS_DYN_SIZE_VER}.patch" 5 || exit 1

    # Download MariaDB repo setup script
    cd_dir "${BUILD_DIR}"
    wget_with_retry "$MARIADB_REPO_LINK" "mariadb_repo_setup" 5 || exit 1

    if [[ ! -e 'mariadb_repo_setup' ]]; then
        # shellcheck disable=SC2059
        printf "${RED}Cannot download mariadb_repo_setup${NC}\n"
        exit 1
    fi

    #echo "c4a0f3dade02c51a6a28ca3609a13d7a0f8910cccbb90935a2f218454d3a914a mariadb_repo_setup" | sha256sum -c -
    chmod +x mariadb_repo_setup

    # Download PHP extensions
    mkdir -p /etc/php
    delete_dir "/etc/php/ioncube"
    delete_file "/etc/php/ioncube_loaders_lin_x86-64.tar.gz"
    cd_dir /etc/php
    wget_with_retry "$IONCUBE_LINK" "ioncube_loaders_lin_x86-64.tar.gz" 5 || exit 1
    run_or_exit "" extract_file ioncube_loaders_lin_x86-64.tar.gz && delete_file ioncube_loaders_lin_x86-64.tar.gz

    cd_dir "${BUILD_DIR}"
    wget_with_retry "$IG_BINARY_LINK" "igbinary-${IG_BINARY_VERSION}.tgz" 5 || return 1
    run_or_exit "" extract_file "igbinary-${IG_BINARY_VERSION}.tgz" && delete_file "igbinary-${IG_BINARY_VERSION}.tgz"

    wget_with_retry "$PHP_MEMCACHED_LINK" "memcached-${PHP_MEMCACHED_VERSION}.tgz" 5 || return 1
    run_or_exit "" extract_file "memcached-${PHP_MEMCACHED_VERSION}.tgz" && delete_file "memcached-${PHP_MEMCACHED_VERSION}.tgz"

    wget_with_retry "$PHP_REDIS_LINK" "redis-${PHP_REDIS_VERSION}.tgz" 5 || return 1
    run_or_exit "" extract_file "redis-${PHP_REDIS_VERSION}.tgz" && delete_file "redis-${PHP_REDIS_VERSION}.tgz"

    if [ -n "$CACHE_TOOL_LINK" ]; then
        wget_with_retry "$CACHE_TOOL_LINK" "cachetool${CACHE_TOOL_VER}" 5 || return 1
    fi

    # Download phpMyAdmin
    if [ -d "${DEFAULT_DIR_TOOL}" ]; then
        delete_dir "${DEFAULT_DIR_TOOL}"
    fi
    mkdir -p "${DEFAULT_DIR_TOOL}"
    cd_dir "${DEFAULT_DIR_TOOL}"

    wget_with_retry "$PHP_MYADMIN_LINK" "phpMyAdmin-${PHPMYADMIN_VERSION}-english.tar.gz" 5 || exit 1
    run_or_exit "" extract_file "phpMyAdmin-${PHPMYADMIN_VERSION}-english.tar.gz" && delete_file "phpMyAdmin-${PHPMYADMIN_VERSION}-english.tar.gz"
    mv phpMyAdmin-"${PHPMYADMIN_VERSION}"-english phpmyadmin

    if [ ! -e "${DEFAULT_DIR_TOOL}/phpmyadmin/index.php" ]; then
        # shellcheck disable=SC2059
        printf "${RED}Cannot download phpMyAdmin${NC}\n"
        exit 1
    fi

    cd_dir "$BUILD_DIR"
    wget_with_retry "${EXT_LINK}/phpmyadmin.sql" "phpmyadmin.sql" 5 || exit 1

    # Download Fail2Ban
    cd_dir "$BUILD_DIR"
    wget_with_retry "$FAIL2BAN_LINK" "fail2ban_${FAIL2BAN_VER}_all.deb" 5 || exit 1

    # Download some cli tools
    ### Download WP-CLI and Composer
    wget_with_retry "$COMPOSER_LINK" "composer" 5 || exit 1
    chmod +x composer && mv composer /usr/local/bin/composer

    wget_with_retry "$WP_CLI_LINK" "wp" 5 || exit 1
    chmod +x wp && mv wp /usr/local/bin/wp

    ### Download acme.sh
    delete_file "${BUILD_DIR}/acme.sh"
    curl -o acme.sh https://get.acme.sh

    if [ ! -e "${BUILD_DIR}/acme.sh" ]; then
        echo "${RED}❌ Khong tai duoc acme.sh${NC}"
        exit 1
    fi

    sh acme.sh email="${ADMIN_EMAIL}"

    ### Download rclone
    delete_file "${BUILD_DIR}/rclone.zip"
    wget_with_retry "${RCLONE_LINK}" "rclone.zip" 5 || exit 1
    run_or_exit "" extract_file "rclone.zip" && delete_file "rclone.zip"
    cd rclone-* || exit 1
    cp rclone /usr/bin/rclone.new
    chmod 755 /usr/bin/rclone.new
    chown root:root /usr/bin/rclone.new
    mv /usr/bin/rclone.new /usr/bin/rclone

    if ! [ -x "$(command -v mandb)" ]; then
        echo 'mandb not found. The rclone man docs will not be installed.'
    else
        mkdir -p /usr/local/share/man/man1
        cp rclone.1 /usr/local/share/man/man1/
        mandb
    fi

    # Download CF IPs
    cd_dir "$BUILD_DIR"
    delete_file "$CF_IPV4_FILE"
    delete_file "$CF_IPV6_FILE"
    wget_with_retry "${CF_IPV4_URL}" "${CF_IPV4_FILE}" 5 || exit 1
    wget_with_retry "${CF_IPV6_URL}" "${CF_IPV6_FILE}" 5 || exit 1

    if [[ ! -s "$CF_IPV4_FILE" ]]; then
        # shellcheck disable=SC2059
        echo "${RED}❌ Khong tai duoc danh sach IPv4 tu Cloudflare${NC}"
        exit 1
    fi

    if [[ ! -s "$CF_IPV6_FILE" ]]; then
        # shellcheck disable=SC2059
        echo "${RED}❌ Khong tai duoc danh sach IPv6 tu Cloudflare${NC}"
        exit 1
    fi

    # Download wp-rocket nginx
    cd_dir "$BUILD_DIR"
    wget_with_retry "$ROCKET_NGINX_LINK" "rocket-nginx-${ROCKET_NGINX_VER}.tar.gz" 5 || exit 1
    run_or_exit "" extract_file "rocket-nginx-${ROCKET_NGINX_VER}.tar.gz" && delete_file "rocket-nginx-${ROCKET_NGINX_VER}.tar.gz"

    # Download menu
    mkdir -p "${BASH_DIR}/data/websites"
    mkdir -p "${BASH_DIR}/data/wp-cron"
    mkdir -p "${BASH_DIR}/tools"
    cd_dir "${BASH_DIR}"
    delete_dir 'server-manager'

    # Uu tien dung server-manager.zip local (upload cung voi install_new)
    if [[ -f "${DIR}/server-manager.zip" ]]; then
        cp "${DIR}/server-manager.zip" "${BASH_DIR}/server-manager.zip"
    else
        wget_with_retry "https://github.com/phongnhadn1991/McnVPS/raw/master/scripts/server-manager.zip" "${BASH_DIR}/server-manager.zip" 5 || exit 1
    fi

    run_or_exit "" extract_file "server-manager.zip" && delete_file "server-manager.zip"
    chmod +x server-manager/* server-manager/*/* server-manager/*/*/*
    dos2unix server-manager/* server-manager/*/* server-manager/*/*/*

    cp "$CF_IPV4_FILE" "${BASH_DIR}/data/cloudflare_ipv4.txt"
    cp "$CF_IPV6_FILE" "${BASH_DIR}/data/cloudflare_ipv6.txt"

    if [[ -n "$CACHE_TOOL_VER" && -e "${BUILD_DIR}/cachetool${CACHE_TOOL_VER}" ]]; then
        chmod +x "${BUILD_DIR}/cachetool${CACHE_TOOL_VER}"
        mv "${BUILD_DIR}/cachetool${CACHE_TOOL_VER}" "${BASH_DIR}/tools/cachetool${CACHE_TOOL_VER}"
    fi
}

############################################
# Install LEMP Stack
############################################
install_nginx() {
    # ignore gcc-14 issues
    export CFLAGS="${CFLAGS} -fpermissive"

    safe_apt_install "cac thu vien can thiet de build Nginx" zlib1g-dev uuid-dev
    apt autoremove -y

    cd_dir "${BUILD_DIR}"/nginx-"${NGINX_VERSION}"/

    run_or_exit "configure Nginx" ./configure \
        "--user=nginx" \
        "--group=nginx" \
        "--prefix=/usr" \
        "--sbin-path=/usr/sbin" \
        "--conf-path=/etc/nginx/nginx.conf" \
        "--pid-path=/var/run/nginx.pid" \
        "--http-log-path=/var/log/nginx/access/access.log" \
        "--error-log-path=/var/log/nginx/errors/error.log" \
        "--without-mail_imap_module" \
        "--without-mail_smtp_module" \
        "--with-http_ssl_module" \
        "--with-http_sub_module" \
        "--with-http_realip_module" \
        "--with-http_stub_status_module" \
        "--with-http_gzip_static_module" \
        "--with-http_dav_module" \
        "--with-http_v2_module" \
        "--with-http_v3_module" \
        "--with-threads" \
        "--with-file-aio" \
        "--with-pcre-jit" \
        "--with-http_geoip_module" \
        "--add-module=../ngx_http_geoip2_module-${ngx_http_geoip2_module_v}" \
        "--add-module=../headers-more-nginx-module-${more_clear_headers_v}" \
        "--add-module=../ngx_brotli" \
        "--with-cc-opt='-D FD_SETSIZE=32768'"

    run_or_exit "Build Nginx" make -j"${CPU_CORES}"

    patch -p1 <nginx__dynamic_tls_records_"${NGX_TLS_DYN_SIZE_VER}".patch

    run_or_exit "Install Nginx" make install -j"${CPU_CORES}"

    # shellcheck disable=SC2002
    # shellcheck disable=SC2143
    if [[ -z "$(cat /etc/passwd | grep nginx)" ]]; then
        run_or_exit "Add Nginx user" adduser --system --home /nonexistent --shell /bin/false --no-create-home \
            --disabled-login --disabled-password --gecos "nginx user" --group nginx
    fi

    cat >"/etc/systemd/system/nginx.service" <<EOnginx_service
[Unit]
Description=The nginx HTTP and reverse proxy server
After=syslog.target network.target remote-fs.target nss-lookup.target

[Service]
Type=forking
PIDFile=/var/run/nginx.pid
ExecStartPre=/usr/sbin/nginx -t -c /etc/nginx/nginx.conf
ExecStart=/usr/sbin/nginx -c /etc/nginx/nginx.conf
ExecReload=/bin/kill -s HUP \$MAINPID
ExecStop=/bin/kill -s QUIT \$MAINPID
PrivateTmp=true
LimitMEMLOCK=infinity
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
EOnginx_service

    systemctl daemon-reload

    if [[ -z "$(which nginx)" ]]; then
        # shellcheck disable=SC2059
        printf "${RED}Install Nginx Failed${NC}\n"
        exit 1
    fi

    mkdir -p "/etc/nginx/modules"
    #mv "${BUILD_DIR}/ngx_http_acme_module.so" /etc/nginx/modules/ngx_http_acme_module.so

    systemctl enable nginx.service
    systemctl start nginx.service
    cd_dir "${DIR}"

}

install_mariadb() {
    safe_apt_install "cac goi can thiet de cai dat MariaDB" apt-transport-https -y

    case "$ID" in
        debian)
            if [[ "$VERSION_ID" == '12' ]]; then
                safe_apt_install "cac goi can thiet de cai dat MariaDB" software-properties-common
            fi
            ;;
        ubuntu)
            safe_apt_install "cac goi can thiet de cai dat MariaDB" software-properties-common
            ;;
    esac

    cd_dir "${BUILD_DIR}"
    ./mariadb_repo_setup --mariadb-server-version="mariadb-${MARIADB_VERSION}"
    apt-get update
    safe_apt_install "MariaDB" mariadb-server mariadb-backup

    if [[ -z "$(which mariadb)" ]]; then
        # shellcheck disable=SC2059
        printf "${RED}Install MariaDB Failed${NC}\n"
        exit 1
    fi
}

_patch_systemd_unit_file() {
    local service_name="$1"
    local unit_file=""

    if [[ -f "/usr/lib/systemd/system/${service_name}.service" ]]; then
        unit_file="/usr/lib/systemd/system/${service_name}.service"
    elif [[ -f "/lib/systemd/system/${service_name}.service" ]]; then
        unit_file="/lib/systemd/system/${service_name}.service"
    else
        echo "❌ Khong tim thay systemd unit cho ${service_name}"
        return 1
    fi

    echo "📦 Dang patch unit file: ${unit_file}"
    cp "$unit_file" "${unit_file}.bak.$(date +%F_%H%M%S)"

    if [[ "$service_name" == 'mariadb' ]]; then
        sed -i "s/LimitNOFILE=.*/LimitNOFILE=655350/g" "$unit_file"
        sed -i "s/PrivateTmp=false/PrivateTmp=true/g" "$unit_file"
    else
        local patches=(
            "LimitNOFILE=65535"
            "LimitMEMLOCK=infinity"
            "PrivateTmp=true"
            "ProtectKernelModules=true"
            "ProtectKernelTunables=true"
            "ProtectControlGroups=true"
            "RestrictRealtime=true"
            "RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX"
        )

        for patch in "${patches[@]}"; do
            if ! grep -q "^${patch}$" "$unit_file"; then
                sed -i "/^ExecReload=/a ${patch}" "$unit_file"
            fi
        done
    fi

    systemctl daemon-reload
}

install_php() {
    safe_apt_install "PHP ${PHP_VERSION}" php"${PHP_VERSION}" php"${PHP_VERSION}"-fpm php"${PHP_VERSION}"-ldap php"${PHP_VERSION}"-zip \
        php"${PHP_VERSION}"-cli php"${PHP_VERSION}"-mysql php"${PHP_VERSION}"-gd php"${PHP_VERSION}"-xml \
        php"${PHP_VERSION}"-mbstring php"${PHP_VERSION}"-common php"${PHP_VERSION}"-soap \
        php"${PHP_VERSION}"-curl php"${PHP_VERSION}"-bcmath php"${PHP_VERSION}"-snmp php"${PHP_VERSION}"-pspell \
        php"${PHP_VERSION}"-gmp php"${PHP_VERSION}"-intl php"${PHP_VERSION}"-enchant \
        php"${PHP_VERSION}"-xmlrpc php"${PHP_VERSION}"-tidy php"${PHP_VERSION}"-opcache php"${PHP_VERSION}"-cli \
        php"${PHP_VERSION}"-dev php"${PHP_VERSION}"-sqlite3

    if [[ ${PHP_MAJOR_VERSION} -lt 8 ]]; then
        safe_apt_install "php-json" php"${PHP_VERSION}"-json
    fi

    if [ "${PHP_VERSION}" == "5.6" ]; then
        safe_apt_install "php5.6-mcrypt" php5.6-mcrypt
    fi

    case "$ID" in
        debian)
            if [[ "$VERSION_ID" == '12' ]]; then
                safe_apt_install "Install php${PHP_VERSION}-imap" "php${PHP_VERSION}-imap"
            fi
            ;;
        ubuntu)
            safe_apt_install "Install php${PHP_VERSION}-imap" "php${PHP_VERSION}-imap"
            ;;
    esac

    if [[ ! -e /usr/bin/php"${PHP_VERSION}" ]]; then
        # shellcheck disable=SC2059
        printf "${RED}Install PHP Failed${NC}\n"
        exit 1
    fi

    _patch_systemd_unit_file "php${PHP_VERSION}-fpm"

    update-alternatives --set php /usr/bin/php"${PHP_VERSION}"
}

_build_php_ext_from_source() {
    local name="$1"
    local version="$2"
    local config_args="$3"
    local ini_priority="$4"

    local folder="$BUILD_DIR/${name}-${version}"
    local ini_file="${PHP_MODULES_PATH}/${name}.ini"

    echo "📦 Dang cai dat extension: ${name} v${version}"

    cd "$folder" || return 1

    run_or_exit "Prepare compile PHP ${name}" /usr/bin/phpize"${PHP_VERSION}"
    # shellcheck disable=SC2086
    run_or_exit "configure PHP ${name}" ./configure --with-php-config="/usr/bin/php-config${PHP_VERSION}" ${config_args}
    run_or_exit "Build PHP ${name}" make -j"${CPU_CORES}"
    run_or_exit "Install PHP ${name}" make install -j"${CPU_CORES}"

    echo "extension=${name}.so" >"$ini_file"
    ln -sf "$ini_file" "${PHP_INI_PATH}/${ini_priority}-${name}.ini"
    ln -sf "$ini_file" "${PHP_CLI_PATH}/${ini_priority}-${name}.ini"

    echo "✅ Cai dat xong ${name}"
}

install_php_ext() {
    _build_php_ext_from_source "igbinary" "${IG_BINARY_VERSION}" "" 30

    local check_igbinary=''
    local memcached_config_args=''
    local redis_config_args='--enable-redis-zstd'

    if [[ -x "/usr/bin/php${PHP_VERSION}" ]]; then
        if /usr/bin/php"${PHP_VERSION}" -m | grep -q '^igbinary$'; then
            check_igbinary='true'
        fi
    fi

    if [[ "$check_igbinary" == 'true' ]]; then
        memcached_config_args='--enable-memcached-igbinary'
        redis_config_args+=' --enable-redis-igbinary'
    fi

    if [[ -e "/usr/include/lz4.h" && -e "/usr/lib/x86_64-linux-gnu/liblz4.so" ]]; then
        redis_config_args+=' --enable-redis-lz4 --with-liblz4=/usr'
    fi

    _build_php_ext_from_source "memcached" "${PHP_MEMCACHED_VERSION}" "$memcached_config_args" 30
    _build_php_ext_from_source "redis" "${PHP_REDIS_VERSION}" "$redis_config_args" 30

    if [[ -e "/etc/php/ioncube/ioncube_loader_lin_${PHP_VERSION}.so" ]]; then
        cat >"${PHP_MODULES_PATH}/ioncube.ini" <<END
zend_extension=/etc/php/ioncube/ioncube_loader_lin_${PHP_VERSION}.so
END

        ln -s "${PHP_MODULES_PATH}/ioncube.ini" "${PHP_INI_PATH}/01-ioncube.ini"
        ln -s "${PHP_MODULES_PATH}/ioncube.ini" "${PHP_CLI_PATH}/01-ioncube.ini"
    fi

    systemctl restart php"${PHP_VERSION}"-fpm.service
}

install_phpmyadmin() {
    if [ "${PHP_VERSION}" != "5.6" ]; then
        DECLARE="declare(strict_types=1);"
    fi

    delete_dir "${DEFAULT_DIR_TOOL}"/phpmyadmin/setup

    mv "${DEFAULT_DIR_TOOL}"/phpmyadmin/config.sample.inc.php "${DEFAULT_DIR_TOOL}"/phpmyadmin/config.inc.php

    BLOWFISH_SECRET=$(random_string 31)
    mkdir -p "${DEFAULT_DIR_TOOL}/phpmyadmin/tmp"  "${DEFAULT_DIR_TOOL}/phpmyadmin/logs"
    touch "${DEFAULT_DIR_TOOL}/phpmyadmin/logs/auth_fail.log"

    cat >"${DEFAULT_DIR_TOOL}/phpmyadmin/config.inc.php" <<EOCONFIGINC
<?php
${DECLARE}
\$cfg['blowfish_secret'] = '${BLOWFISH_SECRET}';
\$i = 0;
\$i++;
\$cfg['Servers'][\$i]['auth_type'] = 'cookie';
\$cfg['Servers'][\$i]['host'] = 'localhost';
\$cfg['Servers'][\$i]['connect_type'] = 'tcp';
\$cfg['Servers'][\$i]['compress'] = false;
\$cfg['Servers'][\$i]['AllowNoPassword'] = false;
\$cfg['UploadDir'] = '';
\$cfg['SaveDir'] = '';
\$cfg['PmaNoRelation_DisableWarning'] = true;
\$cfg['VersionCheck'] = false;
\$cfg['TempDir'] = '${DEFAULT_DIR_TOOL}/phpmyadmin/tmp';
\$cfg['CaptchaLoginPublicKey'] = '';
\$cfg['CaptchaLoginPrivateKey'] = '';
\$cfg['ExecTimeLimit'] = 600;
\$cfg['DefaultCharset'] = 'utf8';
\$cfg['DefaultConnectionCollation'] = 'utf8_general_ci';

\$cfg['AuthLog'] = '${DEFAULT_DIR_TOOL}/phpmyadmin/logs/auth_fail.log';
EOCONFIGINC

    chown -R nginx:nginx "${DEFAULT_DIR_TOOL}"/phpmyadmin

    cat >>"${BUILD_DIR}/phpmyadmin.temp" <<EOphpmyadmin_temp
CREATE DATABASE IF NOT EXISTS phpmyadmin;
FLUSH PRIVILEGES;
EOphpmyadmin_temp

    mariadb -u root -p"${SQL_ROOT_PASS}" <${BUILD_DIR}/phpmyadmin.temp
    delete_file "${BUILD_DIR}/phpmyadmin.temp"

    mariadb -u root -p"${SQL_ROOT_PASS}" phpmyadmin <"${BUILD_DIR}/phpmyadmin.sql" || {
        # shellcheck disable=SC2059
        printf "${RED}❌ Loi khi cai dat phpMyAdmin${NC}"
        exit 1
    }
}

install_wp_cli_packages() {
    sed -i '/memory_limit/d' "${PHP_MODULES_PATH}/mcnvps-custom.ini"
    echo "memory_limit = -1" >>"${PHP_MODULES_PATH}/mcnvps-custom.ini"

    systemctl restart php"${PHP_VERSION}"-fpm

    run_or_exit "Install wp-cli-rename-db-prefix" wp package install iandunn/wp-cli-rename-db-prefix --allow-root
    run_or_exit "Install wp-revisions-cli" wp package install trepmal/wp-revisions-cli --allow-root

    sed -i '/memory_limit/d' "${PHP_MODULES_PATH}/mcnvps-custom.ini"
    echo "memory_limit = ${MAX_MEMORY}M" >>"${PHP_MODULES_PATH}/mcnvps-custom.ini"

    systemctl restart php"${PHP_VERSION}"-fpm
}

############################################
# Dynamic calculation
############################################
php_memory_calculation() {
    if [[ "${PHP_MEM}" -le '262144' ]]; then
        OPCACHE_MEM='128'
        MAX_MEMORY='128'
        PHP_REAL_PATH_LIMIT='512k'
        PHP_REAL_PATH_TTL='14400'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '262144' && "${PHP_MEM}" -le '393216' ]]; then
        OPCACHE_MEM='128'
        MAX_MEMORY='128'
        PHP_REAL_PATH_LIMIT='640k'
        PHP_REAL_PATH_TTL='21600'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '393216' && "${PHP_MEM}" -le '524288' ]]; then
        OPCACHE_MEM='128'
        MAX_MEMORY='128'
        PHP_REAL_PATH_LIMIT='768k'
        PHP_REAL_PATH_TTL='21600'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '524288' && "${PHP_MEM}" -le '1049576' ]]; then
        OPCACHE_MEM='144'
        MAX_MEMORY='160'
        PHP_REAL_PATH_LIMIT='768k'
        PHP_REAL_PATH_TTL='28800'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '1049576' && "${PHP_MEM}" -le '2097152' ]]; then
        OPCACHE_MEM='160'
        MAX_MEMORY='320'
        PHP_REAL_PATH_LIMIT='1536k'
        PHP_REAL_PATH_TTL='28800'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '2097152' && "${PHP_MEM}" -le '3145728' ]]; then
        OPCACHE_MEM='192'
        MAX_MEMORY='384'
        PHP_REAL_PATH_LIMIT='2048k'
        PHP_REAL_PATH_TTL='43200'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '3145728' && "${PHP_MEM}" -le '4194304' ]]; then
        OPCACHE_MEM='224'
        MAX_MEMORY='512'
        PHP_REAL_PATH_LIMIT='3072k'
        PHP_REAL_PATH_TTL='43200'
        MAX_INPUT_VARS="6000"
    elif [[ "${PHP_MEM}" -gt '4194304' && "${PHP_MEM}" -le '8180000' ]]; then
        OPCACHE_MEM='288'
        MAX_MEMORY='640'
        PHP_REAL_PATH_LIMIT='4096k'
        PHP_REAL_PATH_TTL='43200'
        MAX_INPUT_VARS="10000"
    elif [[ "${PHP_MEM}" -gt '8180000' && "${PHP_MEM}" -le '16360000' ]]; then
        OPCACHE_MEM='320'
        MAX_MEMORY='800'
        PHP_REAL_PATH_LIMIT='4096k'
        PHP_REAL_PATH_TTL='43200'
        MAX_INPUT_VARS="10000"
    elif [[ "${PHP_MEM}" -gt '16360000' && "${PHP_MEM}" -le '32400000' ]]; then
        OPCACHE_MEM='480'
        MAX_MEMORY='1024'
        PHP_REAL_PATH_LIMIT='4096k'
        PHP_REAL_PATH_TTL='43200'
        MAX_INPUT_VARS="10000"
    elif [[ "${PHP_MEM}" -gt '32400000' && "${PHP_MEM}" -le '64800000' ]]; then
        OPCACHE_MEM='600'
        MAX_MEMORY='1280'
        PHP_REAL_PATH_LIMIT='4096k'
        PHP_REAL_PATH_TTL='43200'
        MAX_INPUT_VARS="10000"
    elif [[ "${PHP_MEM}" -gt '64800000' ]]; then
        OPCACHE_MEM='800'
        MAX_MEMORY='2048'
        PHP_REAL_PATH_LIMIT='8192k'
        PHP_REAL_PATH_TTL='86400'
        MAX_INPUT_VARS="10000"
    fi
}

php_parameter() {
    if [[ ${CPU_CORES} -ge 4 && ${CPU_CORES} -lt 6 && ${RAM_TOTAL} -gt 1049576 && ${RAM_TOTAL} -le 2097152 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 4 && ${CPU_CORES} -lt 6 && ${RAM_TOTAL} -gt 2097152 && ${RAM_TOTAL} -le 3145728 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 4 && ${CPU_CORES} -lt 6 && ${RAM_TOTAL} -gt 3145728 && ${RAM_TOTAL} -le 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 4 && ${CPU_CORES} -lt 6 && ${RAM_TOTAL} -gt 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 6 && ${CPU_CORES} -lt 8 && ${RAM_TOTAL} -gt 3145728 && ${RAM_TOTAL} -le 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 6 && ${CPU_CORES} -lt 8 && ${RAM_TOTAL} -gt 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 8 && ${CPU_CORES} -lt 16 && ${RAM_TOTAL} -gt 3145728 && ${RAM_TOTAL} -le 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 8 && ${CPU_CORES} -lt 12 && ${RAM_TOTAL} -gt 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 13 && ${CPU_CORES} -lt 16 && ${RAM_TOTAL} -gt 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 6))
        PM_MAX_REQUEST=2000
    elif [[ ${CPU_CORES} -ge 17 && ${RAM_TOTAL} -gt 4194304 ]]; then
        PM_MAX_CHILDREN=$((CPU_CORES * 5))
        PM_MAX_REQUEST=2000
    else
        PM_MAX_CHILDREN=$((CPU_CORES * 5))
        PM_MAX_REQUEST=500
    fi
}

############################################
# Config LEMP
############################################
# Config SSL
self_signed_ssl() {
    #Create dhparams
    self_signed_dir="/etc/nginx/ssl/default"
    mkdir -p "${self_signed_dir}"
    openssl dhparam -out /etc/nginx/ssl/dhparams.pem 2048
    openssl genrsa -out "${self_signed_dir}/server.key" 4096
    openssl req -new -key "${self_signed_dir}/server.key" \
        -out "${self_signed_dir}/server.csr" -subj "/C=VN/ST=Dong Da/L=Hanoi/O=Hostvn.net/OU=IT Department/CN=${IPADDRESS}"
    openssl x509 -in "${self_signed_dir}/server.csr" -out "${self_signed_dir}/server.crt" \
        -req -signkey "${self_signed_dir}/server.key" -days 3650
}

# Config PHP-FPM
php_global_config() {
    if [[ -f "$PHP_CONFIG_PATH/php-fpm.conf" ]]; then
        mv "$PHP_CONFIG_PATH"/php-fpm.conf "$PHP_CONFIG_PATH"/php-fpm.conf."$(date +%Y-%m-%d)"
    fi

    cat >>"$PHP_CONFIG_PATH/php-fpm.conf" <<EOphp_fpm_conf
;;;;;;;;;;;;;;;;;;;;;
; FPM Configuration ;
;;;;;;;;;;;;;;;;;;;;;

include=$PHP_POOL_PATH/*.conf

[global]
pid = /run/php/php${PHP_VERSION}-fpm.pid
error_log = /var/log/php-fpm/error.log
log_level = warning
emergency_restart_threshold = 10
emergency_restart_interval = 1m
process_control_timeout = 10s
daemonize = yes
EOphp_fpm_conf

    if [[ -f "$PHP_POOL_PATH/www.conf" ]]; then
        mv "$PHP_POOL_PATH"/www.conf "$PHP_POOL_PATH"/www.conf."$(date +%Y-%m-%d)"
    fi
    cat >>"$PHP_POOL_PATH/www.conf" <<EOwww_conf
[www]
listen = /var/run/php${PHP_VERSION}-fpm.sock;
listen.allowed_clients = 127.0.0.1
listen.owner = nginx
listen.group = nginx
listen.mode = 0660
user = nginx
group = nginx
pm = ondemand
pm.max_children = ${PM_MAX_CHILDREN}
pm.max_requests = ${PM_MAX_REQUEST}
pm.process_idle_timeout = 20
;slowlog = /var/log/php-fpm/slow/slow.log
chdir = /
php_admin_value[error_log] = /var/log/php-fpm/error/error.log
php_admin_flag[log_errors] = on
php_value[session.save_handler] = files
php_value[session.save_path]    = /var/lib/php/session
php_value[soap.wsdl_cache_dir]  = /var/lib/php/wsdlcache
php_admin_value[disable_functions] = exec,system,passthru,shell_exec,proc_close,proc_open,dl,popen,show_source,posix_kill,posix_mkfifo,posix_getpwuid,posix_setpgid,posix_setsid,posix_setuid,posix_setgid,posix_seteuid,posix_setegid,posix_uname
php_admin_value[open_basedir] = /tmp/:/var/tmp/:/dev/urandom:/usr/share/php/:/dev/shm:/var/lib/php/sessions/:/var/www/
security.limit_extensions = .php
EOwww_conf

    mkdir -p /var/lib/php/session
    mkdir -p /var/lib/php/wsdlcache
    mkdir -p /var/log/php-fpm/slow /var/log/php-fpm/error
    chown -R nginx:nginx /var/lib/php/session
    chown -R nginx:nginx /var/lib/php/wsdlcache
    chown -R nginx:nginx /var/log/php-fpm
    chmod 755 /var/lib/php/session
    chmod 755 /var/lib/php/wsdlcache
}

mcnvps_custom_ini() {
    cat >"${PHP_MODULES_PATH}/mcnvps-custom.ini" <<EOmcnvps_custom_ini
date.timezone = Asia/Ho_Chi_Minh
max_execution_time = 600
max_input_time = 600
short_open_tag = On
realpath_cache_size = ${PHP_REAL_PATH_LIMIT}
realpath_cache_ttl = ${PHP_REAL_PATH_TTL}
memory_limit = ${MAX_MEMORY}M
upload_max_filesize = ${MAX_MEMORY}M
post_max_size = ${MAX_MEMORY}M
expose_php = Off
display_errors = Off
mail.add_x_header = Off
max_input_nesting_level = 128
max_input_vars = ${MAX_INPUT_VARS}
mysqlnd.net_cmd_buffer_size = 16384
mysqlnd.collect_memory_statistics = Off
mysqlnd.mempool_default_size = 16000
always_populate_raw_post_data=-1
error_reporting = E_ALL & ~E_NOTICE
EOmcnvps_custom_ini

    delete_file "${PHP_CLI_PATH}/00-mcnvps-custom.ini"
    delete_file "${PHP_INI_PATH}/00-mcnvps-custom.ini"

    ln -s "${PHP_MODULES_PATH}/mcnvps-custom.ini" "${PHP_CLI_PATH}/00-mcnvps-custom.ini"
    ln -s "${PHP_MODULES_PATH}/mcnvps-custom.ini" "${PHP_INI_PATH}/00-mcnvps-custom.ini"
}

php_opcache() {
    if [[ -e "${PHP_MODULES_PATH}/opcache.ini" ]]; then
        mv "${PHP_MODULES_PATH}/opcache.ini" "${PHP_MODULES_PATH}/opcache.ini.$(date +%Y-%m-%d)"
    fi

    cat >"${PHP_MODULES_PATH}/opcache.ini" <<EOphp_opcache
zend_extension=opcache.so
opcache.jit=disable
opcache.enable=1
opcache.memory_consumption=${OPCACHE_MEM}
opcache.interned_strings_buffer=8
opcache.max_wasted_percentage=5
opcache.max_accelerated_files=65407
opcache.revalidate_freq=180
opcache.fast_shutdown=0
opcache.enable_cli=0
opcache.save_comments=1
opcache.enable_file_override=1
opcache.validate_timestamps=1
opcache.blacklist_filename=${PHP_MODULES_PATH}/opcache-default.blacklist
EOphp_opcache

    cat >"${PHP_MODULES_PATH}/opcache-default.blacklist" <<EOopcache_blacklist
/home/*/*/public_html/wp-content/plugins/backwpup/*
/home/*/*/public_html/wp-content/plugins/duplicator/*
/home/*/*/public_html/wp-content/plugins/updraftplus/*
/home/*/*/public_html/wp-content/cache/*
/home/*/*/public_html/wp-content/uploads/*
/home/*/*/public_html/storage/*
EOopcache_blacklist

    delete_file "${PHP_CLI_PATH}/10-opcache.ini"
    delete_file "${PHP_INI_PATH}/10-opcache.ini"

    ln -s "${PHP_MODULES_PATH}/opcache.ini" "${PHP_CLI_PATH}/10-opcache.ini"
    ln -s "${PHP_MODULES_PATH}/opcache.ini" "${PHP_INI_PATH}/10-opcache.ini"
}

_mysql_secure_installation() {
    expect <<EOF
spawn mysql_secure_installation

expect "Enter current password for root"
send "\r"

expect "Switch to unix_socket authentication"
send "n\r"

expect "Change the root password?"
send "y\r"

expect "New password:"
send "${SQL_ROOT_PASS}\r"

expect "Re-enter new password:"
send "${SQL_ROOT_PASS}\r"

expect "Remove anonymous users?"
send "y\r"

expect "Disallow root login remotely?"
send "y\r"

expect "Remove test database and access to it?"
send "y\r"

expect "Reload privilege tables now?"
send "y\r"

expect eof
EOF

    Q1="CREATE USER IF NOT EXISTS 'sqladmin'@'localhost' IDENTIFIED BY '${SQL_ADMIN_PASS}';"
    Q2="CREATE USER IF NOT EXISTS 'sqladmin'@'127.0.0.1' IDENTIFIED BY '${SQL_ADMIN_PASS}';"
    Q3="GRANT ALL PRIVILEGES ON *.* TO 'sqladmin'@'localhost' WITH GRANT OPTION;"
    Q4="GRANT ALL PRIVILEGES ON *.* TO 'sqladmin'@'127.0.0.1' WITH GRANT OPTION;"
    Q5="FLUSH PRIVILEGES;"

    SQL="${Q1}${Q2}${Q3}${Q4}${Q5}"
    mariadb -u root -e "${SQL}" || {
        # shellcheck disable=SC2059
        printf "${RED}❌ Khong the chay lenh SQL de bao mat MariaDB${NC}"
        exit 1
    }
}

config_my_cnf() {
    mkdir -m 2750 /var/log/mysql
    chown -R mysql:mysql /var/log/mysql

    systemctl start mariadb
    systemctl enable mariadb

    _mysql_secure_installation
    _patch_systemd_unit_file "mariadb"
}

config_nginx() {
    mkdir -p '/etc/nginx/sites-available' '/etc/nginx/sites-enabled' '/etc/nginx/geo' '/etc/nginx/conf.d/wordpress'

    cat >"/etc/nginx/nginx.conf" <<END
worker_processes  auto;
pid /var/run/nginx.pid;
#error_log  /var/log/nginx/errors/error.log;
#error_log  /var/log/nginx/errors/error.log  notice;
#error_log  /var/log/nginx/errors/error.log  info;

events {
    worker_connections  10240;
}

http {
    include       /etc/nginx/mime.types;

    charset utf-8;
    default_type  application/octet-stream;

    tcp_nopush on;
    tcp_nodelay on;

    sendfile        on;
    sendfile_max_chunk 512k;

    log_format  main  '\$remote_addr - \$remote_user [\$time_local] "\$request" '
                      '\$status \$body_bytes_sent "\$http_referer" '
                      '"\$http_user_agent" "\$http_x_forwarded_for" "\$geoip2_asn" "\$geoip2_organization" "\$geoip2_data_country_name" '
                      '\$request_time';

    #log_format bytes '\$bytes_sent \$request_length';

    keepalive_timeout  15;
    types_hash_max_size 2048;

    disable_symlinks if_not_owner from=\$document_root;

    server_tokens off;

    client_max_body_size 1024m;
    client_body_buffer_size 128k;

    server_names_hash_bucket_size 128;
    server_names_hash_max_size 10240;
    variables_hash_max_size 2048;
    variables_hash_bucket_size 128;

    merge_slashes on;

    aio threads;
    directio 4m;

    reset_timedout_connection on;
    lingering_time 20s;
    lingering_timeout 5s;

    ssl_dhparam /etc/nginx/ssl/dhparams.pem;

    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout  5m;

    ssl_early_data on;
    ssl_dyn_rec_enable on;

    # https://mozilla.github.io/server-side-tls/ssl-config-generator/ intermediate configuration.
    ssl_protocols TLSv1.1 TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:DHE-DSS-AES128-GCM-SHA256:kEDH+AESGCM:ECDHE-RSA-AES128-SHA256:ECDHE-ECDSA-AES128-SHA256:ECDHE-RSA-AES128-SHA:ECDHE-ECDSA-AES128-SHA:ECDHE-RSA-AES256-SHA384:ECDHE-ECDSA-AES256-SHA384:ECDHE-RSA-AES256-SHA:ECDHE-ECDSA-AES256-SHA:DHE-RSA-AES128-SHA256:DHE-RSA-AES128-SHA:DHE-DSS-AES128-SHA256:DHE-RSA-AES256-SHA256:DHE-DSS-AES256-SHA:DHE-RSA-AES256-SHA:ECDHE-RSA-DES-CBC3-SHA:ECDHE-ECDSA-DES-CBC3-SHA:AES128-GCM-SHA256:AES256-GCM-SHA384:AES128-SHA256:AES256-SHA256:AES128-SHA:AES256-SHA:AES:CAMELLIA:DES-CBC3-SHA:!aNULL:!eNULL:!EXPORT:!DES:!RC4:!MD5:!PSK:!aECDH:!EDH-DSS-DES-CBC3-SHA:!EDH-RSA-DES-CBC3-SHA:!KRB5-DES-CBC3-SHA';
    ssl_prefer_server_ciphers on;
    resolver             1.1.1.1 1.0.0.1 8.8.8.8 8.8.4.4 valid=10m;
    resolver_timeout     5s;

    # Limit Request
    limit_req_status 444;
    # limit the number of connections per single IP
    limit_conn_zone \$binary_remote_addr zone=conn_limit_per_ip:10m;
    # limit the number of requests for a given session
    limit_req_zone \$binary_remote_addr zone=req_limit_per_ip:10m rate=1r/s;

    index  index.html index.htm index.php;

    include /etc/nginx/conf.d/map.conf;
    include /etc/nginx/nginx-cloudflare.conf;
    include /etc/nginx/nginx-geo.conf;
    include /etc/nginx/nginx-gzip.conf;
    include /etc/nginx/nginx-brotli.conf;
    include /etc/nginx/nginx-headers.conf;
    include /etc/nginx/nginx-proxy.conf;
    include /etc/nginx/nginx-fastcgi-cache.conf;
    include /etc/nginx/conf.d/skip-cache.conf;
    include /etc/nginx/nginx-vhosts.conf;
    include /etc/nginx/sites-enabled/*.conf;
}
END

    CF_CONFIG_FILE="/etc/nginx/nginx-cloudflare.conf"

    {
        echo "real_ip_header CF-Connecting-IP;"
        while read -r ip; do
            [[ -n "$ip" ]] && echo "set_real_ip_from $ip;"
        done < "$CF_IPV4_FILE"

        while read -r ip; do
            [[ -n "$ip" ]] && echo "set_real_ip_from $ip;"
        done < "$CF_IPV6_FILE"
    } > "$CF_CONFIG_FILE"

    cat >"/etc/nginx/nginx-gzip.conf" <<END
gzip on;
gzip_static on;
gzip_disable "msie6";
gzip_http_version 1.1;
gzip_vary on;
gzip_comp_level 1;
gzip_proxied any;
gzip_types text/plain text/css application/json application/x-javascript text/xml application/xml application/xml+rss text/javascript application/javascript text/x-js image/svg+xml;
gzip_buffers 16 8k;
END

    cat >"/etc/nginx/nginx-brotli.conf" <<END
brotli on;
brotli_min_length 1000;
brotli_comp_level 1;
brotli_static on;
brotli_types text/plain text/css application/json application/x-javascript text/xml application/xml application/xml+rss text/javascript application/javascript text/x-js image/svg+xml;
END

    cat >"/etc/nginx/nginx-headers.conf" <<END
more_clear_headers X-Powered-By;
more_clear_headers Server;
more_clear_headers x-turbo-charged-by;
more_clear_headers alt-svc;
more_clear_headers x-redirect-by;
more_set_headers   'Server MCNVPS.NET';
END

    cat >"/etc/nginx/well-known.conf" <<END
location ^~ /.well-known/ {
    root /var/www/html/;
    index index.html index.htm;

    default_type "text/plain";

    location ~* ^/.well-known/(acme-challenge|pki-validation)/.*(\.htaccess|\.htpasswd|\.user\.ini|\.env|\.git)$ {
        deny all;
        access_log off;
        return 444;
    }

    location ~* ^/.well-known/(acme-challenge|pki-validation)/.*\.(?:s?html?|php[0-9]?|pl|py|exe|log|bak|cgi|sh|bash|sql|zip|gz|rar|nok|love|save|old)$ {
        access_log off;
        log_not_found off;
        return 444;
    }

    location ~* ^/.well-known/(acme-challenge|pki-validation)/(.+\.(jpg|jpeg|gif|css|png|js|ico|html|webp|xml|txt))$ {
        root /var/www/html/;
    }
}

location ~* ^/.well-known/.*\.(?:s?html?|php[0-9]?|pl|py|exe|log|bak|cgi|sh|bash|sql|zip|gz|rar|nok|love|save|old)$ {
    access_log off;
    log_not_found off;
    return 444;
}
END

    cat >"/etc/nginx/nginx_limits.conf" <<END
fastcgi_buffer_size 128k;
fastcgi_buffers 256 16k;
fastcgi_busy_buffers_size 256k;
fastcgi_temp_file_write_size 256k;
fastcgi_send_timeout 600;
fastcgi_read_timeout 600;
fastcgi_intercept_errors on;
fastcgi_param HTTP_PROXY "";
END

    cat >"/etc/nginx/nginx-proxy.conf" <<END
proxy_connect_timeout 150s;
proxy_send_timeout    150s;
proxy_read_timeout    1800s;
proxy_buffer_size     128k;
proxy_buffers       4 256k;
proxy_busy_buffers_size 256k;
END

    cat >"/etc/nginx/nginx-vhosts.conf" <<END
server {
    listen 80 default_server reuseport;
    listen [::]:80 default_server reuseport;

    server_name _;
    add_header X-Robots-Tag "noindex, nofollow";

    root $DEFAULT_DIR_WEB;

    if (\$is_bad_ua = 1) {
        return 444;
    }

    if (\$block_sensitive_files = 1) {
        return 444;
    }

    location / {
        index index.html index.htm;
    }
}

server {
    listen 443 quic reuseport default_server;
    listen 443 ssl default_server;
    listen [::]:443 quic reuseport default_server;
    listen [::]:443 ssl default_server;
    http2 on;
    http3 on;
    quic_retry on;

    server_name _;

    ssl_certificate /etc/nginx/ssl/default/server.crt;
    ssl_certificate_key /etc/nginx/ssl/default/server.key;

    add_header X-Robots-Tag "noindex, nofollow";

    if (\$is_bad_ua = 1) {
        return 444;
    }

    if (\$block_sensitive_files = 1) {
        return 444;
    }

    root $DEFAULT_DIR_WEB;

    include /etc/nginx/well-known.conf;

    location / {
        index index.html index.htm;
    }
}

server {
    listen ${RANDOM_ADMIN_PORT};
    listen [::]:${RANDOM_ADMIN_PORT};

    server_name ${IPADDRESS};

    access_log off;
    log_not_found off;
    error_log /var/log/nginx/errors/error.log;

    add_header X-Robots-Tag "noindex, nofollow";

    root ${DEFAULT_DIR_TOOL};
    index index.php index.html index.htm;

    location ^~ /phpmyadmin {
        root ${DEFAULT_DIR_TOOL}/;
        index index.php index.html index.htm;
        location ~ ^/phpmyadmin/(.+\.php)\$ {
            try_files \$uri =404;
            fastcgi_split_path_info ^(.+\.php)(/.+)\$;
            fastcgi_index index.php;
            include /etc/nginx/fastcgi_params;
            include /etc/nginx/nginx_limits.conf;
            fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;

            if (-f \$request_filename)
            {
                fastcgi_pass unix:/var/run/php${PHP_VERSION}-fpm.sock;
            }
        }
        location ~* ^/phpmyadmin/(.+\.(jpg|jpeg|gif|css|png|js|ico|html|webp|xml|txt))\$ {
            root ${DEFAULT_DIR_TOOL}/;
        }
    }

    location ~ ^/pma { rewrite ^/* /phpmyadmin last; }
    location ^~ /phpmyadmin/locale/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/doc/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/log/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/logs/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/tmp/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/libraries/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/templates/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/sql/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/vendor/ { return 444; access_log off; log_not_found off; }
    location ^~ /phpmyadmin/examples/ { return 444; access_log off; log_not_found off; }
}
END

